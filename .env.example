# Copy this file to backend/.env and fill in your keys.
# (load_dotenv() is called from the backend/ working directory.)

# --- Nebius AI Studio (LLM: extract + script) ---
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.ai/v1
# IMPORTANT: verify this model id exists in your Nebius dashboard.
# Good options: deepseek-ai/DeepSeek-V3, Qwen/Qwen2.5-72B-Instruct, meta-llama/Llama-3.3-70B-Instruct
NEBIUS_MODEL=deepseek-ai/DeepSeek-V3

# --- Tavily (article extract + deep search) ---
TAVILY_API_KEY=

# --- Gradium (TTS) ---
# NOTE: Gradium TTS supports English/French/German/Spanish/Portuguese only (NO Chinese).
GRADIUM_API_KEY=
# Optional region override, e.g. eu.api.gradium.ai/api  (leave blank for SDK default)
GRADIUM_BASE_URL=
# Default voice from the official Gradium example; pick others from their voice library.
GRADIUM_VOICE_ID=YTpq7expH9539ERJ

# Spoken words per minute used to compute the time budget (English ~150).
WPM=150
