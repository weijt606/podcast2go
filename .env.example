# Copy this file to backend/.env and fill in what you need.
# Defaults use free/open-source engines, so the only key you must set is the LLM.

# ============ LLM (required) ============
# OpenAI-compatible. Use Nebius, or point at a local Ollama for zero-cost:
#   NEBIUS_BASE_URL=http://localhost:11434/v1   NEBIUS_API_KEY=ollama   NEBIUS_MODEL=llama3.1
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.ai/v1
# Verify this model id exists in your provider dashboard.
NEBIUS_MODEL=deepseek-ai/DeepSeek-V3

# ============ Engine selection ============
# Defaults are free/open-source — no keys needed beyond the LLM.
TTS_PROVIDER=edge              # edge (free) | gradium
SEARCH_PROVIDER=duckduckgo     # duckduckgo (free) | tavily
EXTRACT_PROVIDER=trafilatura   # trafilatura (free) | tavily
STT_PROVIDER=whisper           # whisper (needs: pip install faster-whisper)

# ============ Optional: edge-tts ============
# Auto-picks a voice by output language; override here if you want a specific one.
# e.g. en-US-AriaNeural, zh-CN-XiaoxiaoNeural, ja-JP-NanamiNeural
EDGE_VOICE=

# ============ Optional: whisper (STT for audio/podcast URLs) ============
WHISPER_MODEL=base             # tiny | base | small | medium | large-v3

# ============ Optional: Tavily (only if SEARCH/EXTRACT = tavily) ============
TAVILY_API_KEY=

# ============ Optional: Gradium (only if TTS_PROVIDER=gradium) ============
# NOTE: Gradium TTS supports English/French/German/Spanish/Portuguese only (no Chinese).
GRADIUM_API_KEY=
GRADIUM_BASE_URL=
GRADIUM_VOICE_ID=YTpq7expH9539ERJ

# Spoken words per minute used to compute the time budget.
WPM=150
