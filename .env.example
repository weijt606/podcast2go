# Copy this file to backend/.env and fill in your LLM endpoint.
# The bundled TTS / search / extract engines are free and need NO keys —
# the only thing you must configure is an LLM.

# ============ LLM (required) ============
# Any OpenAI-compatible endpoint. Pick ONE and uncomment it (or use your own):
#
#   OpenAI      LLM_BASE_URL=https://api.openai.com/v1            LLM_MODEL=gpt-4o-mini
#   Groq        LLM_BASE_URL=https://api.groq.com/openai/v1       LLM_MODEL=llama-3.3-70b-versatile
#   DeepSeek    LLM_BASE_URL=https://api.deepseek.com/v1          LLM_MODEL=deepseek-chat
#   Zhipu GLM   LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4 LLM_MODEL=glm-4-flash
#   OpenRouter  LLM_BASE_URL=https://openrouter.ai/api/v1         LLM_MODEL=deepseek/deepseek-chat
#   Ollama      LLM_BASE_URL=http://localhost:11434/v1           LLM_MODEL=llama3.1   (LLM_API_KEY=ollama)
#
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ============ TTS (bundled: edge-tts, free) ============
# Auto-picks a voice by output language; override with a specific edge voice if you like.
# e.g. en-US-AriaNeural, zh-CN-XiaoxiaoNeural, ja-JP-NanamiNeural
EDGE_VOICE=
# Use a custom OpenAI-compatible TTS API instead (e.g. OpenAI /v1/audio/speech):
#   TTS_ENGINE=api  TTS_BASE_URL=https://api.openai.com/v1  TTS_API_KEY=sk-...  TTS_MODEL=tts-1  TTS_VOICE=alloy
# (Also selectable + testable from the UI settings panel.) Leave TTS_ENGINE blank/edge for built-in edge-tts.
TTS_ENGINE=edge
# Other engines (Piper offline / CosyVoice / VoxCPM local) — add a branch in backend/providers/tts.py.

# ============ STT for audio/podcast URLs (bundled: faster-whisper) ============
# Needs: pip install faster-whisper
WHISPER_MODEL=base             # tiny | base | small | medium | large-v3

# Search (DuckDuckGo) and article extraction (trafilatura) are bundled and free.
# To swap in a search/extract API (Tavily, Brave, Serper, Mercury, …) edit
# backend/providers/search.py or backend/providers/extract.py.

# Spoken words per minute used to compute the time budget.
WPM=150
